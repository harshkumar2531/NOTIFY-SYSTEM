
POSTGRES_DSN=postgresql://notify:notify_pass@localhost:5432/notifydb

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=notifydb

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MQTT (VerneMQ) ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=backend
MQTT_PASSWORD=backend-secret

# --- API security ---
API_KEY=dev-secret-change-me

# --- JWT auth ---
JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_MINUTES=2
REFRESH_TOKEN_DAYS=7
